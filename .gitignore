dist/
build/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*

# Environment & secrets (never commit)
.env
.env.*
!.env.example
*.pem
**/service-account*.json
**/google-credentials.json
**/credentials.json
**/*-credentials.json

# IDEs & editors
.vscode/
.idea/
.cursor/
.claude/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test output
test-output/
**/test-output/
coverage/

# Generated files
scripts/*.html

# NPM artifacts
*.tgz

# TSC output leaked into src
packages/mcp/src/**/*.js
packages/mcp/src/**/*.js.map
packages/mcp/src/**/*.d.ts
packages/mcp/src/**/*.d.ts.map

# reframe local data (generated at runtime)
.reframe/

# MCP config (user-specific)
.mcp.json

