# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*

# Environment & secrets (never commit)
.env
.env.*
!.env.example
*.pem
**/service-account*.json
**/google-credentials.json
**/credentials.json
**/*-credentials.json

# IDEs & editors
.vscode/
.idea/
.cursor/
.claude/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Test output
test-output/
**/test-output/
coverage/

# Dev scripts (exploration harnesses, stress tests, phase verifiers).
# These are situational — written for specific debugging sessions
# and go stale fast. Proper regression tests live under
# packages/*/src/tests/ and run via `npm test`.
scripts/

# NPM artifacts
*.tgz

# TSC output leaked into src
packages/mcp/src/**/*.js
packages/mcp/src/**/*.js.map
packages/mcp/src/**/*.d.ts
packages/mcp/src/**/*.d.ts.map

# reframe local data (generated at runtime)
# Covers .reframe/scenes, /exports, /brands, /src, design.md, phase*-report.md
.reframe/

# MCP config (user-specific paths/api keys)
.mcp.json

# Phase scratch reports outside .reframe/
phase*-report.md
*-scratch.md
