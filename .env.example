# Copy to `.env` in the repo root (already gitignored). Never commit real values.
#
# Google Fonts Web Fonts API — optional; without a key, fetches from Google Fonts are skipped
# (system / bundled fonts still work). Create a key: Google Cloud Console → APIs → Credentials.
GOOGLE_FONTS_API_KEY=

# MCP: skip auto-starting the HTTP sidecar when scenes are stored (e.g. unit scripts that call storeScene)
# REFRAME_SKIP_HTTP_SIDECAR=1
